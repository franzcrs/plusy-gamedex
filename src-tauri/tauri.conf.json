{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PlusY Gamedex",
  "version": "0.1.0",
  "identifier": "com.franzcrs.plusy-gamedex",
  "build": {
    "beforeDevCommand": "yarn dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "yarn build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "PlusY Gamedex",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "Apple Development: franz.chuquirachi@gmail.com (2VZFVC6GY2)",
      "hardenedRuntime": true,
      "entitlements": "./entitlements.plist"
    }
  }
}