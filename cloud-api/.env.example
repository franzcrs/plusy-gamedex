# ═══════════════════════════════════════════════════════════════════
# PlusY Gamedex Environment Configuration
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════════

# Google Cloud Configuration
# List of available regions: https://cloud.google.com/run/docs/locations
PROJECT_ID=your-gcp-project-id
BUCKET_NAME=your-gamedex-storage-bucket
REGION=us-central1

# ═══════════════════════════════════════════════════════════════════
# 📍 DOMAIN CONFIGURATION
# ═══════════════════════════════════════════════════════════════════

# Development & Production Demo: Your Cloudflare domain
# (Dev uses Tunnel, Prod uses DNS to Cloud Run)
PERSONAL_DOMAIN=gamedex.yourdomain.com

# Client Production: Wix domain (final production)
# 🔄 This will be the active Cloud API domain after client handoff
CLIENT_DOMAIN=gamedex.clientdomain.com

# ═══════════════════════════════════════════════════════════════════
# Firebase Configuration
# ═══════════════════════════════════════════════════════════════════

# Path to Firebase service account key (for server-side verification)
GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json

# ═══════════════════════════════════════════════════════════════════
# Server Configuration
# ═══════════════════════════════════════════════════════════════════

# Port for Cloud API (Cloud Run injects this automatically)
PORT=8080
